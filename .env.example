# Prisma / Supabase Postgres
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@TRANSACTION_POOLER_HOST:6543/postgres"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@HOST:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
